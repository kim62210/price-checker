# ------------------------------------------------------------------
# 외부 API 키
# ------------------------------------------------------------------
# 네이버 개발자센터에서 애플리케이션 등록 후 발급 (필수)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# LLM 폴백: Ollama 로컬 우선, 실패 시 OpenAI 폴백
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MONTHLY_TOKEN_CAP=2000000

# ------------------------------------------------------------------
# 데이터 스토어
# ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://lowestprice:lowestprice@localhost:5432/lowestprice
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------
# Rate / Throttle
# ------------------------------------------------------------------
NAVER_RPM=30
COUPANG_RPM=10

# ------------------------------------------------------------------
# 원격 쿠팡 스크레이퍼 (Mac mini Tailnet)
# ------------------------------------------------------------------
# Playwright connect_over_cdp 로 개인 Chrome 에 붙어 Akamai 우회
# 기본값은 Mac mini Tailnet IP. OCI 운영 서버에서도 동일 값 사용
COUPANG_SCRAPER_URL=http://100.70.111.100:8081
COUPANG_SCRAPER_TIMEOUT_SECONDS=45
NAVER_DAILY_QUOTA=25000
PLAYWRIGHT_CONCURRENCY=2
REQUEST_JITTER_MIN_MS=500
REQUEST_JITTER_MAX_MS=2000

# ------------------------------------------------------------------
# 캐시 TTL (초)
# ------------------------------------------------------------------
SEARCH_CACHE_TTL_SECONDS=600
DETAIL_CACHE_TTL_SECONDS=21600
OPTION_CACHE_TTL_SECONDS=86400

# ------------------------------------------------------------------
# 파서
# ------------------------------------------------------------------
PARSER_VERSION=1

# ------------------------------------------------------------------
# 관측성
# ------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
ENVIRONMENT=local

# ------------------------------------------------------------------
# 서비스
# ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:8501
