# ------------------------------------------------------------------
# 데이터 스토어
# ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://lowestprice:lowestprice@localhost:5432/lowestprice
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------
# LLM (옵션)
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MONTHLY_TOKEN_CAP=2000000

# ------------------------------------------------------------------
# 캐시 TTL (초)
# ------------------------------------------------------------------
SEARCH_CACHE_TTL_SECONDS=600
OPTION_CACHE_TTL_SECONDS=86400

# ------------------------------------------------------------------
# 파서
# ------------------------------------------------------------------
PARSER_VERSION=1

# ------------------------------------------------------------------
# 관측성
# ------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
ENVIRONMENT=local

# ------------------------------------------------------------------
# 서비스
# ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------
# 프로덕션 환경에서는 반드시 재정의 (HS256 서명 시크릿, 32바이트 이상 권장)
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# ------------------------------------------------------------------
# OAuth: Kakao
# ------------------------------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

# ------------------------------------------------------------------
# OAuth: Naver
# ------------------------------------------------------------------
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/naver/callback

# ------------------------------------------------------------------
# Tenant 기본값
# ------------------------------------------------------------------
DEFAULT_TENANT_API_QUOTA_MONTHLY=10000
